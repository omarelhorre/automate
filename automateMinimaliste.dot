digraph G {
init [shape=point shape=point style=filled, fillcolor=white color=white];
fin [shape=point shape=point style=filled, fillcolor=white color=white];
init -> 0;
0 -> 1 [label="a"];
0 -> 2 [label="b"];
1 -> 2 [label="a"];
1 -> 1 [label="b"];
2 -> 1 [label="a"];
2 -> 2 [label="b"];
2 -> fin;
}
